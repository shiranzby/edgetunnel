# Dependencies
node_modules/

# Cloudflare / Wrangler local state
.wrangler/
wrangler.toml
.wrangler*.toml
!wrangler.example.toml

# Local logs and dev output
*.log
*.out.log
*.err.log
tail.*.log
wrangler-dev.*.log

# Generated subscriptions and runtime data
clash-*.yaml
remote-result.json
mixed-live.txt
admin-config.json

# Local deployment helpers that may contain private values
deploy-with-token.bat
shyvpn.config.yaml
local-cfst-dashboard/config.json
